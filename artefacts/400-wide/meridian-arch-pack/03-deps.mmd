    htmlLabels: true
    curve: basis
---
graph TD

  POS["<b>POS Client</b><br/>store terminal browser"]

  Gateway["<b>Apollo GraphQL Gateway</b><br/>Node.js / Apollo Server"]

  Identity["<b>Identity Service</b><br/>Node.js / Express + PostgreSQL"]
  Cart["<b>Cart Service</b><br/>Node.js / Express + Redis"]
  Checkout["<b>Checkout Service</b><br/>Node.js / Express"]
  Inventory["<b>Inventory Read Cache</b><br/>Redis<br/><i>ContainerDb</i>"]
  EventBus["<b>Order Event Bus</b><br/>Apache Kafka<br/><i>ContainerQueue</i>"]
  OrderDb["<b>Order Database</b><br/>PostgreSQL<br/><i>ContainerDb</i>"]

  Stripe["<b>Stripe</b><br/>System_Ext"]
  SAP["<b>SAP ECC</b><br/>System_Ext"]
  Auth0["<b>Auth0</b><br/>System_Ext"]
  CRM["<b>Salesforce Marketing Cloud</b><br/>System_Ext"]
  SendGrid["<b>SendGrid</b><br/>System_Ext"]

  POS -->|"JSON/HTTPS<br/>lookupCustomerCart(qrCode, storeId)<br/>p95 ≤ 80ms"| Gateway
  Gateway -->|"gRPC<br/>validateAssociateSession<br/>p95 ≤ 15ms"| Identity
  Gateway -->|"gRPC<br/>resolveLoyaltyQr<br/>p95 ≤ 15ms"| Identity
  Gateway -->|"gRPC<br/>getActiveCart<br/>p95 ≤ 15ms"| Cart
  Cart -->|"RESP/TCP<br/>getStock(storeId, sku) per line item<br/>p95 ≤ 3ms each"| Inventory
  Cart -->|"IDoc sync<br/>checkStockRealtime — cache-miss fallback<br/>p95 ≤ 400ms"| SAP
  SAP -.->|"SFTP/IDoc batch 15–30 min<br/>async cache hydration<br/>stock levels + sell-through velocity"| Inventory

  Cart -.->|"Kafka/TCP<br/>publishes CartItemAdded, CartItemRemoved,<br/>CartAbandoned"| EventBus
  Identity -.->|"Kafka/TCP<br/>publishes CustomerRegistered,<br/>LoyaltyTierChanged, ConsentUpdated"| EventBus
  Checkout -.->|"Kafka/TCP<br/>publishes OrderPlaced, PaymentAuthorised,<br/>PaymentCaptured, OrderFulfilled"| EventBus

  Identity -->|"OAuth 2.0 / OIDC<br/>resolveUserProfile"| Auth0
  Identity -->|"JSON/HTTPS<br/>syncCustomerSegments"| CRM
  Checkout -->|"JSON/HTTPS<br/>authorise + capture"| Stripe
  Checkout -->|"JSON/HTTPS<br/>dispatchOrderEmail"| SendGrid
  Checkout -->|"SQL/TCP<br/>insert + update orders"| OrderDb

  Gateway -->|"gRPC<br/>suggestAlternativeStores<br/>p95 ≤ 15ms + RESP MGET ≤ 10ms"| Inventory

